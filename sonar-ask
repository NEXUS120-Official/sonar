#!/bin/bash
# File: sonar-ask
# Rendi eseguibile: chmod +x sonar-ask

set -e  # Ferma lo script se c'è un errore

# ===== CONFIGURAZIONE =====
DEEPSEEK_API_KEY="${DEEPSEEK_API_KEY}"  # Va impostata come variabile d'ambiente
CONTEXT_FILE=".sonar_context.txt"
MAX_CONTEXT_CHARS=50000  # Massimo caratteri da inviare a DeepSeek
CACHE_DURATION_HOURS=1   # Ogni quanto rigenerare il contesto

# ===== COLORI PER OUTPUT =====
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# ===== FUNZIONI =====
print_header() {
    echo -e "${BLUE}🔍 SONAR AI ASSISTANT${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

print_error() {
    echo -e "${RED}❌ Errore: $1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_info() {
    echo -e "${YELLOW}ℹ️  $1${NC}"
}

# ===== CHECK PRELIMINARI =====
check_api_key() {
    if [ -z "$DEEPSEEK_API_KEY" ]; then
        print_error "DEEPSEEK_API_KEY non impostata!"
        echo ""
        echo "Impostala con:"
        echo "  export DEEPSEEK_API_KEY='sk-la-tua-chiave'"
        echo ""
        echo "Oppure aggiungila al tuo ~/.bashrc o ~/.zshrc"
        exit 1
    fi
}

check_dependencies() {
    local missing_deps=()
    
    for cmd in curl jq git; do
        if ! command -v "$cmd" &> /dev/null; then
            missing_deps+=("$cmd")
        fi
    done
    
    if [ ${#missing_deps[@]} -gt 0 ]; then
        print_error "Dipendenze mancanti: ${missing_deps[*]}"
        echo ""
        echo "Installa con:"
        echo "  brew install curl jq git  # macOS"
        echo "  sudo apt install curl jq git  # Linux"
        exit 1
    fi
}

# ===== GENERAZIONE CONTESTO =====
should_regenerate_context() {
    if [ ! -f "$CONTEXT_FILE" ]; then
        return 0  # File non esiste
    fi
    
    # Controlla se è più vecchio di CACHE_DURATION_HOURS
    if [ "$(uname)" == "Darwin" ]; then
        # macOS
        local file_age=$(($(date +%s) - $(stat -f %m "$CONTEXT_FILE")))
    else
        # Linux
        local file_age=$(($(date +%s) - $(stat -c %Y "$CONTEXT_FILE")))
    fi
    
    local max_age=$((CACHE_DURATION_HOURS * 3600))
    
    if [ $file_age -gt $max_age ]; then
        return 0  # File troppo vecchio
    fi
    
    return 1  # File ancora valido
}

generate_context() {
    print_info "Generazione del contesto del repository..."
    print_info "Questo potrebbe richiedere qualche secondo..."
    
    # Inizia con una panoramica del repository
    echo "# SONAR PROJECT ANALYSIS" > "$CONTEXT_FILE"
    echo "Generated: $(date)" >> "$CONTEXT_FILE"
    echo "" >> "$CONTEXT_FILE"
    
    # 1. Struttura delle directory
    echo "## 📁 PROJECT STRUCTURE" >> "$CONTEXT_FILE"
    echo '```' >> "$CONTEXT_FILE"
    if git rev-parse --git-dir > /dev/null 2>&1; then
        git ls-files | sort >> "$CONTEXT_FILE"
    else
        find . -type f \
            -not -path '*/node_modules/*' \
            -not -path '*/.git/*' \
            -not -path '*/dist/*' \
            -not -path '*/build/*' \
            -not -path '*/__pycache__/*' \
            -not -path '*.pyc' \
            -not -path '*.log' | sort >> "$CONTEXT_FILE"
    fi
    echo '```' >> "$CONTEXT_FILE"
    echo "" >> "$CONTEXT_FILE"
    
    # 2. File di configurazione
    echo "## ⚙️ CONFIGURATION FILES" >> "$CONTEXT_FILE"
    for config_file in package.json pyproject.toml Cargo.toml Makefile CMakeLists.txt Dockerfile docker-compose.yml .gitignore README.md; do
        if [ -f "$config_file" ]; then
            echo "" >> "$CONTEXT_FILE"
            echo "### 📄 $config_file" >> "$CONTEXT_FILE"
            echo '```' >> "$CONTEXT_FILE"
            cat "$config_file" >> "$CONTEXT_FILE"
            echo '```' >> "$CONTEXT_FILE"
        fi
    done
    
    # 3. File di codice principali (limita a 30 file più importanti)
    echo "" >> "$CONTEXT_FILE"
    echo "## 💻 SOURCE CODE (Top 30 files)" >> "$CONTEXT_FILE"
    
    local file_count=0
    find . -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.rs" -o -name "*.go" -o -name "*.java" -o -name "*.cpp" -o -name "*.h" \) \
        -not -path '*/node_modules/*' \
        -not -path '*/target/*' \
        -not -path '*/vendor/*' | sort | while IFS= read -r file; do
        
        file_count=$((file_count + 1))
        if [ $file_count -gt 30 ]; then
            break
        fi
        
        # Leggi il file (massimo 2000 caratteri per file)
        local content=$(head -c 2000 "$file" 2>/dev/null)
        
        echo "" >> "$CONTEXT_FILE"
        echo "### 📝 $file ($(wc -l < "$file" | tr -d ' ') lines)" >> "$CONTEXT_FILE"
        echo '```' >> "$CONTEXT_FILE"
        echo "$content" >> "$CONTEXT_FILE"
        if [ "$(wc -c < "$file")" -gt 2000 ]; then
            echo "" >> "$CONTEXT_FILE"
            echo "... [File truncated, showing first 2000 characters] ..." >> "$CONTEXT_FILE"
        fi
        echo '```' >> "$CONTEXT_FILE"
    done
    
    # 4. Git log recente (se è un repo git)
    if git rev-parse --git-dir > /dev/null 2>&1; then
        echo "" >> "$CONTEXT_FILE"
        echo "## 📜 RECENT GIT HISTORY" >> "$CONTEXT_FILE"
        echo '```' >> "$CONTEXT_FILE"
        git log --oneline -10 >> "$CONTEXT_FILE" 2>/dev/null
        echo '```' >> "$CONTEXT_FILE"
        
        echo "" >> "$CONTEXT_FILE"
        echo "## 🌿 CURRENT BRANCH" >> "$CONTEXT_FILE"
        echo '```' >> "$CONTEXT_FILE"
        git branch --show-current >> "$CONTEXT_FILE" 2>/dev/null
        echo '```' >> "$CONTEXT_FILE"
    fi
    
    print_success "Contesto generato: $(wc -l < "$CONTEXT_FILE") lines, $(wc -c < "$CONTEXT_FILE") bytes"
}

# ===== COMUNICAZIONE CON DEEPSEEK =====
ask_deepseek() {
    local query="$1"
    local context="$2"
    
    print_info "Consultando DeepSeek..."
    print_info "Query: ${query:0:100}..."
    
    # Preparazione del payload JSON in modo sicuro
    local system_prompt="Sei un assistente AI esperto che aiuta a sviluppare il progetto Sonar. Analizza il codice fornito e rispondi in modo dettagliato ma conciso. Puoi suggerire implementazioni, individuare bug, proporre miglioramenti architetturali e spiegare il funzionamento del codice.

Ecco il contesto del progetto:

$context

Usa queste informazioni per dare risposte precise e contestualizzate. Se vedi problemi, evidenziali e proponi soluzioni concrete con codice."
    
    # Escape del JSON
    local escaped_system=$(echo "$system_prompt" | jq -Rs .)
    local escaped_query=$(echo "$query" | jq -Rs .)
    
    # Chiamata API
    local response=$(curl -s -X POST "https://api.deepseek.com/v1/chat/completions" \
        -H "Authorization: Bearer $DEEPSEEK_API_KEY" \
        -H "Content-Type: application/json" \
        -d "{
            \"model\": \"deepseek-chat\",
            \"messages\": [
                {\"role\": \"system\", \"content\": $escaped_system},
                {\"role\": \"user\", \"content\": $escaped_query}
            ],
            \"temperature\": 0.7,
            \"max_tokens\": 4000
        }")
    
    # Controllo errori
    if [ $? -ne 0 ]; then
        print_error "Chiamata API fallita"
        exit 1
    fi
    
    # Estrai la risposta
    local content=$(echo "$response" | jq -r '.choices[0].message.content // empty')
    
    if [ -z "$content" ]; then
        print_error "Risposta vuota o errore API"
        echo "$response" | jq '.'
        exit 1
    fi
    
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo -e "${GREEN}🤖 RISPOSTA DI DEEPSEEK:${NC}"
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "$content"
    echo ""
    echo -e "${BLUE}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
}

# ===== MAIN =====
main() {
    print_header
    
    # Controlli iniziali
    check_api_key
    check_dependencies
    
    # Gestione argomenti
    case "${1:-}" in
        --refresh|-r)
            print_info "Forzando rigenerazione del contesto..."
            rm -f "$CONTEXT_FILE"
            generate_context
            exit 0
            ;;
        --context|-c)
            if [ -f "$CONTEXT_FILE" ]; then
                echo "Contesto esistente: $(date -r "$CONTEXT_FILE" 2>/dev/null || stat -c %y "$CONTEXT_FILE")"
                echo "Dimensione: $(wc -c < "$CONTEXT_FILE") bytes"
                echo "Linee: $(wc -l < "$CONTEXT_FILE")"
            else
                echo "Nessun contesto generato. Esegui prima una query."
            fi
            exit 0
            ;;
        --help|-h)
            echo "Uso: ./sonar-ask [opzioni] <domanda>"
            echo ""
            echo "Opzioni:"
            echo "  --refresh, -r     Rigenera il contesto del progetto"
            echo "  --context, -c     Mostra info sul contesto attuale"
            echo "  --help, -h        Mostra questo aiuto"
            echo ""
            echo "Esempi:"
            echo "  ./sonar-ask 'Come funziona il sistema di autenticazione?'"
            echo "  ./sonar-ask 'Suggerisci come implementare una cache Redis'"
            echo "  ./sonar-ask 'Ci sono vulnerabilità di sicurezza in questo codice?'"
            exit 0
            ;;
    esac
    
    # Se non ci sono argomenti, mostra aiuto
    if [ $# -eq 0 ]; then
        print_error "Devi specificare una domanda!"
        echo "Uso: ./sonar-ask 'la tua domanda'"
        exit 1
    fi
    
    # Genera o aggiorna il contesto se necessario
    if should_regenerate_context; then
        generate_context
    else
        print_info "Usando contesto esistente ($(date -r "$CONTEXT_FILE" 2>/dev/null || stat -c %y "$CONTEXT_FILE"))"
    fi
    
    # Leggi il contesto (limitato a MAX_CONTEXT_CHARS)
    print_info "Caricamento contesto..."
    local context=$(head -c $MAX_CONTEXT_CHARS "$CONTEXT_FILE")
    print_success "Contesto caricato: ${#context} caratteri"
    
    # Invia la domanda
    ask_deepseek "$*" "$context"
}

# Esegui main
main "$@"
