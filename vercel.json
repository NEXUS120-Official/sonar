{
  "functions": {
    "src/app/api/cron/update-balances/route.ts": { "maxDuration": 300 },
    "src/app/api/cron/process-flows/route.ts":   { "maxDuration": 60  },
    "src/app/api/cron/backfill-whale-history/route.ts": { "maxDuration": 120 }
  },
  "crons": [
    {
      "path": "/api/cron/process-flows",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/send-alerts",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/update-balances",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/discover-whales",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/generate-weekly-report",
      "schedule": "0 0 * * 1"
    },
    {
      "path": "/api/cron/resolve-outcomes",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/update-whale-stats",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/detect-token-signals",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/backfill-whale-history",
      "schedule": "0 */6 * * *"
    }
  ]
}
